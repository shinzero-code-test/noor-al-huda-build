{
  "name": "noor-al-huda-mobile",
  "version": "1.5.0",
  "main": "index.ts",
  "scripts": {
    "start": "node ./node_modules/expo/bin/cli start",
    "android": "node ./node_modules/expo/bin/cli run:android",
    "ios": "node ./node_modules/expo/bin/cli run:ios",
    "web": "node ./node_modules/expo/bin/cli start --web",
    "reset": "node ./node_modules/expo/bin/cli start --clear",
    "test": "node ./node_modules/jest/bin/jest.js --runInBand",
    "test:watch": "node ./node_modules/jest/bin/jest.js --watch",
    "test:firebase": "node ./scripts/firebase.integration.mjs",
    "typecheck": "tsc --noEmit",
    "postinstall": "patch-package",
    "doctor": "PATH=\"/data/data/com.termux/files/home/Noor-Al-Huda/bin:$PATH\" node ./node_modules/expo-doctor/build/index.js",
    "prebuild:android": "CI=1 PATH=\"/data/data/com.termux/files/home/Noor-Al-Huda/bin:$PATH\" node ./node_modules/expo/bin/cli prebuild --platform android --no-install",
    "prebuild:ios": "CI=1 PATH=\"/data/data/com.termux/files/home/Noor-Al-Huda/bin:$PATH\" node ./node_modules/expo/bin/cli prebuild --platform ios --no-install"
  },
